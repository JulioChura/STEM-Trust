# Django Settings
# Generate a new SECRET_KEY in production: python manage.py shell -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True

# Google OAuth
# Get these from: https://console.cloud.google.com/
# Project Settings > Credentials > OAuth 2.0 Client IDs > Web client
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
